APP_NAME=SupportMemory
ENVIRONMENT=development
API_PREFIX=/api
FRONTEND_ORIGIN=http://localhost:3000
DATABASE_URL=postgresql://tracememory:tracememory@postgres:5432/tracememory_dev
DATABASE_POOL_MIN_SIZE=1
DATABASE_POOL_MAX_SIZE=10
DATABASE_COMMAND_TIMEOUT_SECONDS=30

# Live model gateway. Configure the selected provider; production does not synthesize model responses.
DEFAULT_MODEL_GATEWAY=qwen
QWEN_API_KEY=
QWEN_MODEL=qwen-max
QWEN_VL_MODEL=qwen-vl-max
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# Voice on Qwen Cloud only (TTS + ASR). Language self-adjusts from user preference.
QWEN_TTS_MODEL=qwen3-tts-flash
QWEN_TTS_VOICE=Cherry
QWEN_TTS_LANGUAGE=Auto
QWEN_ASR_MODEL=qwen3-asr-flash
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4.1-mini
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
# auto = Qwen text-embedding-v3 when QWEN_API_KEY is set, else hash
EMBEDDING_PROVIDER=auto
EMBEDDING_DIMENSIONS=384
QWEN_EMBEDDING_MODEL=text-embedding-v3
GATEWAY_TIMEOUT_SECONDS=45

# Custom Runtime Governor (SupportMemory default = hybrid)
# hybrid = redact on reads/internal tools; strict on external (send_*/refund_*)
# Also: redact | block | require_approval
RUNTIME_GOVERNOR_MODE=local
RUNTIME_GOVERNOR_PII_MODE=hybrid
# When hybrid: block | require_approval for external actions with PII
RUNTIME_GOVERNOR_EXTERNAL_PII_MODE=require_approval
RUNTIME_GOVERNOR_BLOCK_UNKNOWN_TOOLS=false
RUNTIME_GOVERNOR_TOOL_ALLOWLIST=

# Alibaba Cloud — OSS receipt archival + deployment target
ALIBABA_ACCESS_KEY_ID=
ALIBABA_ACCESS_KEY_SECRET=
ALIBABA_OSS_REGION=oss-ap-southeast-1
ALIBABA_OSS_ENDPOINT=https://oss-ap-southeast-1.aliyuncs.com
ALIBABA_OSS_BUCKET=

# Optional adapters only. Not required by SupportMemory core.
FIREWORKS_API_KEY=

# Enterprise adoption controls
AUTH_REQUIRED=false
SIGNING_SECRET=replace-with-a-secure-secret
BOOTSTRAP_ADMIN_TOKEN=replace-in-production
DEFAULT_ORGANISATION_ID=org_default
DEFAULT_WORKSPACE_ID=wrk_default
DEFAULT_PROJECT_ID=prj_default
DEFAULT_ENVIRONMENT_ID=dev
AUDIT_LOG_RETENTION_DAYS=365
RUN_RETENTION_DAYS=365
ENABLE_OPEN_TELEMETRY=false
OTEL_SERVICE_NAME=tracememory-api
WORKER_POLL_INTERVAL_SECONDS=5
WORKER_LEASE_SECONDS=300

# OpenClaw plugin
TRACEMEMORY_API_URL=http://localhost:8000/api
TRACEMEMORY_API_KEY=
TRACEMEMORY_WORKSPACE_ID=wrk_default
TRACEMEMORY_PROJECT_ID=prj_default

# Production runtime
MODEL_PROVIDER=qwen
HACKATHON_TRACK=Track 1: MemoryAgent (Qwen Cloud / Alibaba Cloud)
# Governed automatic execution-memory learning
MEMORY_AUTO_LEARN=true
MEMORY_MIN_AUTO_CONFIDENCE=0.70
MEMORY_DEFAULT_RETENTION_DAYS=365

# PostgreSQL-backed relationship memory
KNOWLEDGE_GRAPH_ENABLED=true
KNOWLEDGE_GRAPH_MAX_DEPTH=2
KNOWLEDGE_GRAPH_MAX_PATHS=12
