{
  "name": "tracememory-hackathon-vultr",
  "private": true,
  "version": "0.1.0-hackathon",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:console": "npm --workspace @tracememory/console run dev",
    "dev:agent": "npm --workspace @tracememory/ticket-agent-demo run dev",
    "build:console": "npm --workspace @tracememory/console run build",
    "build:agent": "npm --workspace @tracememory/ticket-agent-demo run build",
    "api:dev": "cd services/api && uvicorn app.main:app --reload --host 0.0.0.0 --port 8000",
    "test:api": "cd services/api && python -m pytest tests"
  },
  "description": "TraceMemory hackathon build: execution continuity for long-running AI agents deployed on Vultr."
}